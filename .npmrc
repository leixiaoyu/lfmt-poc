# Enforce the `engines` field in package.json at install time.
#
# Without this flag, the `engines` constraint is documentation-only — npm
# install will happily run on a Node version below the floor, defeating the
# purpose of declaring a minimum. With engine-strict=true, `npm install` /
# `npm ci` exit non-zero when the active Node or npm version falls below the
# constraint, surfacing the issue at the earliest possible point (developer
# workstation or CI install step) instead of as a confusing runtime failure
# downstream.
#
# Floor is set in the root package.json `engines` field (Node >=22.11.0,
# npm >=10.9.0 — Node 22 LTS baseline as of 2026-05). Bump there, not here.
engine-strict=true

# npm-audit footgun reminder (PR #203 R4 — security-auditor opportunistic
# follow-up): `npm audit` reads the package-lock.json, NOT the actual
# `node_modules/` tree. If you bump a vulnerable dep in package.json
# WITHOUT regenerating the lockfile (e.g., editing the package.json by
# hand and then running `npm ci`), audit will keep reporting the OLD
# vulnerable version — even though the installed module is fine — until
# you re-run `npm install` (which writes a fresh lockfile). Conversely,
# if you `npm install` a newer dep and `git checkout` the old lockfile,
# audit will report the OLD CLEAN version while the installed module is
# stale + vulnerable. Always re-run `npm install` after package.json
# edits, and always commit lockfile changes alongside package.json edits.
