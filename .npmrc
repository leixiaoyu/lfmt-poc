# Enforce the `engines` field in package.json at install time.
#
# Without this flag, the `engines` constraint is documentation-only — npm
# install will happily run on a Node version below the floor, defeating the
# purpose of declaring a minimum. With engine-strict=true, `npm install` /
# `npm ci` exit non-zero when the active Node or npm version falls below the
# constraint, surfacing the issue at the earliest possible point (developer
# workstation or CI install step) instead of as a confusing runtime failure
# downstream.
#
# Floor is set in the root package.json `engines` field (Node >=22.11.0,
# npm >=10.9.0 — Node 22 LTS baseline as of 2026-05). Bump there, not here.
engine-strict=true
